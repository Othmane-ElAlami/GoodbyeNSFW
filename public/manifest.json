{
  "manifest_version": 3,
  "name": "GoodbyeNSFW",
  "version": "2.0.0",
  "description": "Clean up your Reddit subscriptions and hide NSFW content from your feed.",
  "permissions": [
    "cookies",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://old.reddit.com/*",
    "https://oauth.reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GoodbyeNSFW"
  },
  "content_scripts": [
    {
      "matches": ["https://www.reddit.com/*", "https://old.reddit.com/*"],
      "js": ["content/nsfwBlocker.js"],
      "css": ["content/nsfwBlocker.css"],
      "run_at": "document_idle"
    }
  ]
}
